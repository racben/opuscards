#!/usr/bin/env bash
# opus — one front door for the whole card pipeline, git-style verbs.
#
# Bare `opus` prints help; the daily paths are the vocab/sent verbs (alias whichever
# you use most). Verbs route to the individual tools, which keep working standalone —
# this is only a dispatcher.
set -euo pipefail
# Resolve through symlinks (e.g. ~/bin/opus -> this repo) so the scripts,
# prompts, and _index are found next to the REAL file, wherever it's invoked from.
DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

usage() {
  cat <<'EOF'
usage:
  opus vocab [flags]        clipboard captures -> vocab cards in Anki    (the daily path)
  opus sent  [flags]        clipboard captures -> sentence cards in Anki
  opus vocab|sent --file F  ...from a plaintext inbox instead of the clipboard
  opus mine  [flags]        captures -> TSV records only (preview; no API, no Anki)
  opus pairs [flags]        captures -> plain 'word<TAB>sentence' list (no API, no Anki)
  opus cards [flags]        TSV on stdin -> cards (review-only; add --anki to file them)
  opus add   FILE|DIR ...   copy into the corpus and index it   (corpus.py add; --merge ...)
  opus build [PATH ...]     (re)build the index                 (corpus.py build; --clean ...)

vocab/sent set the batch's default card type; a '>' line prefix still forces a
sentence card per line either way. Unlisted flags on vocab/sent/mine pass through
to opusmine (-d etc.).
Suggested alias:  alias ov='opus vocab'
EOF
}

# Split "--file X" out of the args: captures come from that file instead of the
# clipboard; everything else is handed to opusmine untouched.
SRC_CMD=(pbpaste)
MINE_ARGS=()
parse_source() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file) SRC_CMD=(cat "$2"); shift 2 ;;
      *)      MINE_ARGS+=("$1"); shift ;;
    esac
  done
}

run_pipeline() {  # $@ = extra opusmine args (the default card type)
  "${SRC_CMD[@]}" \
    | uv run "$DIR/opusmine.py" "$@" "${MINE_ARGS[@]}" \
    | uv run "$DIR/opuscards.py" --anki
}

case "${1-}" in
  vocab)
    shift; parse_source "$@"
    run_pipeline ;;
  sent)
    shift; parse_source "$@"
    run_pipeline --type sentence ;;
  add|build)
    sub="$1"; shift
    exec python3 "$DIR/corpus.py" "$sub" "$@" ;;
  mine)
    shift; parse_source "$@"
    "${SRC_CMD[@]}" | uv run "$DIR/opusmine.py" "${MINE_ARGS[@]}" ;;
  pairs)
    shift; parse_source "$@"
    "${SRC_CMD[@]}" | uv run "$DIR/opusmine.py" "${MINE_ARGS[@]}" | cut -f2,3 ;;
  cards)
    shift
    exec uv run "$DIR/opuscards.py" "$@" ;;
  ''|help|-h|--help)
    usage ;;
  *)
    echo "opus: unknown verb '$1'" >&2; echo >&2
    usage >&2; exit 2 ;;
esac
