#!/usr/bin/env bash
# opus — one front door for the whole card pipeline, git-style verbs.
#
# The bare command stays the daily path (clipboard -> cards); verbs route to the
# other tools, which keep working standalone — this is only a dispatcher.
set -euo pipefail
# Resolve through symlinks (e.g. ~/bin/opus -> this repo) so the scripts,
# prompt, and _index are found next to the REAL file, wherever it's invoked from.
DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

usage() {
  cat <<'EOF'
usage:
  opus [flags]              clipboard captures -> cards in Anki   (the daily path)
  opus --file FILE [flags]  ...from a plaintext inbox instead of the clipboard
  opus mine  [flags]        captures -> TSV records only (preview; no API, no Anki)
  opus cards [flags]        TSV on stdin -> cards (review-only; add --anki to file them)
  opus add   FILE|DIR ...   copy into the corpus and index it   (corpus.py add; --merge ...)
  opus build [PATH ...]     (re)build the index                 (corpus.py build; --clean ...)

Unlisted flags on the bare/mine forms pass through to opusmine (-d etc.).
Suggested alias:  alias om='opus'
EOF
}

# Split "--file X" out of the args: captures come from that file instead of the
# clipboard; everything else is handed to opusmine untouched.
SRC_CMD=(pbpaste)
MINE_ARGS=()
parse_source() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --file) SRC_CMD=(cat "$2"); shift 2 ;;
      *)      MINE_ARGS+=("$1"); shift ;;
    esac
  done
}

case "${1-}" in
  add|build)
    sub="$1"; shift
    exec python3 "$DIR/corpus.py" "$sub" "$@" ;;
  mine)
    shift; parse_source "$@"
    "${SRC_CMD[@]}" | uv run "$DIR/opusmine.py" "${MINE_ARGS[@]}" ;;
  cards)
    shift
    exec uv run "$DIR/opuscards.py" "$@" ;;
  help|-h|--help)
    usage ;;
  *)
    parse_source "$@"
    "${SRC_CMD[@]}" \
      | uv run "$DIR/opusmine.py" "${MINE_ARGS[@]}" \
      | uv run "$DIR/opuscards.py" --anki ;;
esac
